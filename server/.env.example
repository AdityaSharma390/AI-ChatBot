# Express Server Config
PORT=5000
NODE_ENV=development

# Database Config
MONGODB_URI=mongodb://localhost:27017/ai-chat-assistant

# Authentication Session Secret
JWT_SECRET=your_jwt_super_secret_key_change_me_in_production

# AI Engine Models & API Keys
# Gemini API Key from Google AI Studio (Required for Chat)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI API Key (Optional fallback for Chat and DALL-E Image Generation)
OPENAI_API_KEY=your_openai_api_key_here

# Frontend Application Origin (For CORS Settings)
CLIENT_URL=http://localhost:5173
